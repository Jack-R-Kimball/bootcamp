---
import { getPanels, getCategories } from '../lib/db.js';
import { renderMain } from '../lib/render.js';

const panels = getPanels();
const activePanel = panels[0];
const categories = activePanel ? getCategories(activePanel.id) : [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <script is:inline>
    (function () {
      var t = localStorage.getItem('theme');
      if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d1117;
      --surface:   #161b22;
      --surface2:  #21262d;
      --border:    #30363d;
      --text:      #e6edf3;
      --muted:     #7d8590;
      --link:      #58a6ff;
      --link-hv:   #79c0ff;
      --accent:    #f78166;
      --accent-hv: #e8705a;
      --danger:    #f85149;
      --r: 4px;
    }

    /* System preference: light */
    @media (prefers-color-scheme: light) {
      :root {
        --bg:        #f6f8fa;
        --surface:   #ffffff;
        --surface2:  #eaeef2;
        --border:    #d0d7de;
        --text:      #1f2328;
        --muted:     #656d76;
        --link:      #0969da;
        --link-hv:   #0550ae;
        --accent:    #c0392b;
        --accent-hv: #a93226;
        --danger:    #cf222e;
      }
    }

    /* Explicit overrides — win over media query */
    html[data-theme="dark"] {
      --bg:        #0d1117;
      --surface:   #161b22;
      --surface2:  #21262d;
      --border:    #30363d;
      --text:      #e6edf3;
      --muted:     #7d8590;
      --link:      #58a6ff;
      --link-hv:   #79c0ff;
      --accent:    #f78166;
      --accent-hv: #e8705a;
      --danger:    #f85149;
    }
    html[data-theme="light"] {
      --bg:        #f6f8fa;
      --surface:   #ffffff;
      --surface2:  #eaeef2;
      --border:    #d0d7de;
      --text:      #1f2328;
      --muted:     #656d76;
      --link:      #0969da;
      --link-hv:   #0550ae;
      --accent:    #c0392b;
      --accent-hv: #a93226;
      --danger:    #cf222e;
    }

    [x-cloak] { display: none !important; }

    body {
      font-family: ui-monospace, 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
      font-size: 13px;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 1.5rem 1.25rem;
      line-height: 1.5;
    }

    .container { max-width: 1200px; margin: 0 auto; }

    /* ── Header ─────────────────────────────────────────── */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
      padding-bottom: 0.875rem;
      border-bottom: 1px solid var(--border);
    }

    /* ── Theme toggle ────────────────────────────────────── */
    .theme-toggle { display: flex; gap: 0.125rem; }
    .theme-toggle button {
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 0.15rem 0.4rem;
    }
    .theme-toggle button:hover { color: var(--text); background: var(--surface2); }
    .theme-toggle button.active { color: var(--accent); }
    .header h1 {
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
    }

    /* ── Panel bar ──────────────────────────────────────── */
    .panel-bar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.875rem;
      flex-wrap: wrap;
    }
    .panel-tabs {
      display: flex;
      gap: 0.25rem;
      flex-wrap: wrap;
    }
    .panel-tab {
      display: flex;
      align-items: center;
      border: 1px solid var(--border);
      border-radius: var(--r);
      overflow: hidden;
    }
    .panel-tab--active {
      border-color: var(--accent);
      background: var(--surface2);
    }
    .panel-tab__btn {
      padding: 0.25rem 0.625rem;
      color: var(--muted);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: 0;
    }
    .panel-tab__btn:hover { color: var(--text); background: var(--surface2); }
    .panel-tab--active .panel-tab__btn { color: var(--accent); }
    .panel-tab__del {
      padding: 0.125rem 0.3rem;
      font-size: 0.75rem;
      border-left: 1px solid var(--border);
      border-radius: 0;
    }
    .panel-actions { display: flex; align-items: center; }
    .panel-add-btn { font-size: 0.6875rem; color: var(--muted); }
    .panel-add-btn:hover { color: var(--link); }

    /* ── Action bar ─────────────────────────────────────── */
    .action-bar { margin-bottom: 1rem; }

    /* ── Categories grid ────────────────────────────────── */
    #categories {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0.75rem;
      align-items: start;
    }
    .empty { color: var(--muted); font-size: 0.8125rem; }

    /* ── Category card ──────────────────────────────────── */
    .category {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r);
    }
    .category-header {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.5rem 0.75rem;
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
      border-left: 3px solid var(--accent);
    }
    .category-title {
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text);
      flex: 1;
    }

    /* ── Links ──────────────────────────────────────────── */
    .links-list { padding: 0.25rem 0; }
    .link-item  { position: relative; }
    .link-row {
      display: flex;
      align-items: center;
      padding: 0.2rem 0.75rem;
      gap: 0.5rem;
    }
    .link-info {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
    }
    .link-name {
      color: var(--link);
      text-decoration: none;
      font-size: 0.8125rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .link-name:hover { color: var(--link-hv); text-decoration: underline; }
    .link-desc {
      display: none;
      font-size: 0.6875rem;
      color: var(--muted);
      line-height: 1.3;
    }
    .link-item:hover .link-desc { display: block; }
    .link-actions {
      position: absolute;
      right: 0.5rem;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      gap: 0.125rem;
      align-items: center;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--r);
      padding: 0.125rem 0.25rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.5);
      z-index: 10;
    }

    /* ── Add link section ───────────────────────────────── */
    .add-link {
      padding: 0.375rem 0.75rem;
      border-top: 1px solid var(--border);
    }
    .add-link-btn {
      font-size: 0.6875rem;
      color: var(--muted);
      width: 100%;
      text-align: left;
      padding: 0.125rem 0;
      font-family: inherit;
    }
    .add-link-btn:hover { color: var(--link); }

    /* ── Edit form ──────────────────────────────────────── */
    .edit-form { padding: 0.375rem 0.75rem; }

    /* ── Category rename ────────────────────────────────── */
    .cat-actions { display: flex; align-items: center; gap: 0.125rem; }
    .cat-rename-form { flex: 1; }
    .cat-rename-form input[name="name"] { width: auto; flex: 1; min-width: 60px; }

    /* ── Drag handles ───────────────────────────────────── */
    .drag-handle {
      cursor: grab;
      color: var(--muted);
      opacity: 0.4;
      flex-shrink: 0;
      user-select: none;
      font-size: 0.875rem;
      line-height: 1;
    }
    .drag-handle:hover { opacity: 1; color: var(--text); }
    .drag-handle:active { cursor: grabbing; }
    .sortable-ghost { opacity: 0.25; }
    /* forceFallback clone: must be pointer-events:none so elementFromPoint
       looks through it to the element beneath (e.g. a panel tab). */
    .sortable-fallback { pointer-events: none !important; box-shadow: 0 4px 16px rgba(0,0,0,0.5); opacity: 0.9; }
    .links-list { min-height: 1.5rem; }

    /* ── Panel tab as drag-over drop zone ───────────────── */
    .tab-drop-hover { border-color: var(--link); }
    .tab-drop-hover .panel-tab__btn { color: var(--link); background: rgba(88,166,255,0.12); }

    /* ── Cross-panel drag overlay ────────────────────────── */
    .panel-drag-overlay {
      position: fixed;
      z-index: 50;
      background: var(--bg);
      border: 1px solid var(--link);
      border-radius: var(--r);
      padding: 0.75rem;
      box-shadow: 0 8px 32px rgba(0,0,0,0.7);
      overflow-y: auto;
      max-height: 60vh;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0.75rem;
      align-items: start;
    }
    /* Hide interactive controls — overlay is a drop-target only */
    .panel-drag-overlay .cat-actions,
    .panel-drag-overlay .link-actions,
    .panel-drag-overlay .add-link { display: none !important; }

    /* ── Inline forms ───────────────────────────────────── */
    .inline-form {
      display: flex;
      gap: 0.375rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .inline-form input {
      border: 1px solid var(--border);
      border-radius: var(--r);
      padding: 0.2rem 0.5rem;
      font-size: 0.75rem;
      font-family: inherit;
      outline: none;
      min-width: 0;
      background: var(--bg);
      color: var(--text);
    }
    .inline-form input::placeholder { color: var(--muted); }
    .inline-form input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(247,129,102,0.15);
    }
    .inline-form input[name="name"]        { width: 120px; }
    .inline-form input[name="url"]         { width: 185px; }
    .inline-form input[name="description"] { width: 185px; }

    /* ── Buttons ────────────────────────────────────────── */
    button {
      cursor: pointer;
      border: none;
      background: none;
      font-family: inherit;
      font-size: 0.6875rem;
      border-radius: var(--r);
      padding: 0.2rem 0.5rem;
      line-height: 1.5;
    }
    .btn-primary { background: var(--accent); color: #fff; font-weight: 700; letter-spacing: 0.03em; }
    .btn-primary:hover { background: var(--accent-hv); }
    .btn-ghost { color: var(--muted); }
    .btn-ghost:hover { background: var(--surface2); color: var(--text); }
    .btn-danger { color: var(--danger); padding: 0.1rem 0.375rem; }
    .btn-danger:hover { background: rgba(248,81,73,0.1); }
    .btn-action { color: var(--muted); }
    .btn-action:hover { background: var(--surface2); color: var(--text); }
    .btn-action.del:hover { color: var(--danger); background: rgba(248,81,73,0.1); }

    /* ── Touch / mobile: hover-only elements become always-on ───────────── */
    @media (hover: none) {
      .link-desc { display: block; }
    }

    /* ── Small screen layout ────────────────────────────────────────────── */
    @media (max-width: 600px) {
      body { padding: 1rem 0.75rem; }
      .inline-form { flex-direction: column; align-items: stretch; }
      .inline-form input { width: 100% !important; }
      .inline-form button { align-self: flex-start; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Dashboard</h1>
      <div x-data="themeToggle" class="theme-toggle">
        <button @click="set('light')" :class="{ active: mode === 'light' }">light</button>
        <button @click="set('system')" :class="{ active: mode === 'system' }">auto</button>
        <button @click="set('dark')"  :class="{ active: mode === 'dark'  }">dark</button>
      </div>
    </div>
    <div id="main" set:html={renderMain(panels, activePanel?.id, categories)}></div>
  </div>

  <script>
    import Alpine from 'alpinejs';
    import 'htmx.org';
    import Sortable from 'sortablejs';

    window.Alpine = Alpine;

    Alpine.data('themeToggle', () => ({
      mode: localStorage.getItem('theme') || 'system',
      set(m) {
        this.mode = m;
        if (m === 'system') {
          localStorage.removeItem('theme');
          document.documentElement.removeAttribute('data-theme');
        } else {
          localStorage.setItem('theme', m);
          document.documentElement.setAttribute('data-theme', m);
        }
      },
    }));

    Alpine.start();

    // Track mouse position with a listener registered at page-load, BEFORE
    // SortableJS adds any listeners. This fires reliably during forceFallback
    // drags regardless of what SortableJS does with later mousemove listeners.
    let _mx = 0, _my = 0;
    document.addEventListener('mousemove', e => { _mx = e.clientX; _my = e.clientY; });
    document.addEventListener('touchmove', e => {
      const t = e.touches[0];
      if (t) { _mx = t.clientX; _my = t.clientY; }
    }, { passive: true });

    let _catSortable      = null;
    let _linkSortables    = [];
    let _dragPoll         = null;
    let _tabHoverEl       = null;
    let _tabHoverTimer    = null;
    let _overlay          = null;
    let _overlaySortables = [];
    let _overlayPanelId   = null;
    let _overlayPanelBtn  = null;

    function saveCatOrder() {
      const catsEl = document.getElementById('categories');
      if (!catsEl) return;
      const ids = [...catsEl.querySelectorAll(':scope > .category')]
        .map(el => Number(el.dataset.id));
      fetch('/api/categories/reorder', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids }),
      });
    }

    function closeOverlay() {
      if (!_overlay) return;
      _overlaySortables.forEach(s => { try { s.destroy(); } catch {} });
      _overlaySortables = [];
      _overlay.remove();
      _overlay         = null;
      _overlayPanelId  = null;
      _overlayPanelBtn = null;
    }

    // Clears the tab highlight and cancels the hover timer.
    // Does NOT close the overlay — that only happens in onEnd.
    function clearTabHover() {
      clearTimeout(_tabHoverTimer); _tabHoverTimer = null;
      if (_tabHoverEl) { _tabHoverEl.classList.remove('tab-drop-hover'); _tabHoverEl = null; }
    }

    async function showPanelOverlay(panelId, btn) {
      if (_overlayPanelId === panelId && _overlay) return; // already showing
      closeOverlay();

      const resp = await fetch(`/api/categories?panel_id=${panelId}`);
      if (!resp.ok) return;
      const html = await resp.text();
      // Skip if target panel has no categories yet.
      if (!html.includes('class="category"')) return;

      const panelBar = document.querySelector('.panel-bar');
      const rect = panelBar
        ? panelBar.getBoundingClientRect()
        : { bottom: 60, left: 16 };
      const maxW = window.innerWidth - rect.left - 16;

      _overlay = document.createElement('div');
      _overlay.className = 'panel-drag-overlay';
      _overlay.style.top   = (rect.bottom + 8) + 'px';
      _overlay.style.left  = rect.left + 'px';
      _overlay.style.width = Math.min(760, maxW) + 'px';
      _overlay.innerHTML   = html;
      document.body.appendChild(_overlay);

      _overlayPanelId  = panelId;
      _overlayPanelBtn = btn;

      _overlay.querySelectorAll('.links-list').forEach(list => {
        const s = Sortable.create(list, {
          group: 'links',
          handle: '.link-drag-handle',
          animation: 150,
          forceFallback: true,
          fallbackTolerance: 3,
        });
        _overlaySortables.push(s);
      });
    }

    // Poll every 50 ms during a link drag: highlight the panel tab under the
    // cursor and, after 500 ms of hover, show the target panel's categories as
    // a floating drop-target overlay.
    function checkTabHover() {
      const el = document.elementFromPoint(_mx, _my);
      // While cursor is inside the overlay, leave everything alone.
      if (_overlay && _overlay.contains(el)) return;

      const tab = el?.closest('.panel-tab');
      if (!tab) { clearTabHover(); return; }
      if (_tabHoverEl === tab) return; // still on same tab

      clearTabHover();
      _tabHoverEl = tab;
      tab.classList.add('tab-drop-hover');

      const btn = tab.querySelector('.panel-tab__btn');
      const m = (btn?.getAttribute('hx-get') || '').match(/panel_id=(\d+)/);
      if (m) {
        const panelId = Number(m[1]);
        _tabHoverTimer = setTimeout(() => showPanelOverlay(panelId, btn), 500);
      }
    }

    function addLinkSortables() {
      document.querySelectorAll('.links-list').forEach(list => {
        if (list._si) return;
        list._si = Sortable.create(list, {
          group: 'links',
          handle: '.link-drag-handle',
          animation: 150,
          forceFallback: true,
          fallbackTolerance: 3,
          onStart() { _dragPoll = setInterval(checkTabHover, 50); },
          onEnd(evt) {
            clearInterval(_dragPoll); _dragPoll = null;

            // Capture overlay state before clearing — closeOverlay() detaches
            // the overlay DOM, but detached nodes are still traversable.
            const itemInOverlay = _overlay && _overlay.contains(evt.item);
            const savedBtn      = _overlayPanelBtn;

            const under    = document.elementFromPoint(_mx, _my);
            const panelTab = itemInOverlay
              ? null
              : (under?.closest('.panel-tab') ?? _tabHoverEl);

            clearTabHover();
            closeOverlay();

            if (itemInOverlay) {
              // Dropped into a specific category in the overlay.
              const catEl = evt.item.closest('.category');
              if (!catEl) return;
              const linksList  = catEl.querySelector('.links-list');
              const categoryId = Number(catEl.dataset.id);
              const ids = [...linksList.querySelectorAll(':scope > .link-item')]
                .map(el => Number(el.dataset.id));
              fetch('/api/links/reorder', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ids, category_id: categoryId }),
              }).then(r => { if (r.ok && savedBtn) savedBtn.click(); });
              return;
            }

            if (panelTab) {
              // Dropped directly on a tab (no overlay) → first category fallback.
              const btn = panelTab.querySelector('.panel-tab__btn');
              const m = (btn?.getAttribute('hx-get') || '').match(/panel_id=(\d+)/);
              if (!m) return;
              fetch('/api/links/move-to-panel', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ link_id: Number(evt.item.dataset.id), panel_id: Number(m[1]) }),
              }).then(r => { if (r.ok) btn.click(); });
              return;
            }

            // Normal in-panel sort / cross-category move.
            const catEl = evt.item.closest('.category');
            if (!catEl?.isConnected) return;
            const linksList  = catEl.querySelector('.links-list');
            const categoryId = Number(catEl.dataset.id);
            const ids = [...linksList.querySelectorAll(':scope > .link-item')]
              .map(el => Number(el.dataset.id));
            fetch('/api/links/reorder', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ ids, category_id: categoryId }),
            });
          },
        });
        _linkSortables.push(list._si);
      });
    }

    function initSortable() {
      if (_catSortable) { _catSortable.destroy(); _catSortable = null; }
      _linkSortables.forEach(s => { try { s.destroy(); } catch {} });
      _linkSortables = [];
      document.querySelectorAll('.links-list').forEach(l => delete l._si);

      const catsEl = document.getElementById('categories');
      if (catsEl) {
        _catSortable = Sortable.create(catsEl, {
          handle: '.cat-drag-handle',
          animation: 150,
          onEnd: saveCatOrder,
        });
      }
      addLinkSortables();
    }

    initSortable();

    document.addEventListener('htmx:afterSwap', (evt) => {
      const id = evt.target.id;
      if (id === 'categories' || id === 'main') initSortable();
      if (id === 'categories') {
        const ab = document.querySelector('.action-bar');
        if (ab) { Alpine.$data(ab).adding = false; ab.querySelector('form')?.reset(); }
      }
    });
  </script>
</body>
</html>
