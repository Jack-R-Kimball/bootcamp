---
import { getPanels, getCategories } from '../lib/db.js';
import { renderMain } from '../lib/render.js';

const panels = getPanels();
const activePanel = panels[0];
const categories = activePanel ? getCategories(activePanel.id) : [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0d1117;
      --surface:  #161b22;
      --surface2: #21262d;
      --border:   #30363d;
      --text:     #e6edf3;
      --muted:    #7d8590;
      --link:     #58a6ff;
      --link-hv:  #79c0ff;
      --accent:   #f78166;
      --danger:   #f85149;
      --r: 4px;
    }

    [x-cloak] { display: none !important; }

    body {
      font-family: ui-monospace, 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
      font-size: 13px;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 1.5rem 1.25rem;
      line-height: 1.5;
    }

    .container { max-width: 1200px; margin: 0 auto; }

    /* ── Header ─────────────────────────────────────────── */
    .header {
      display: flex;
      align-items: center;
      margin-bottom: 1.25rem;
      padding-bottom: 0.875rem;
      border-bottom: 1px solid var(--border);
    }
    .header h1 {
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
    }

    /* ── Panel bar ──────────────────────────────────────── */
    .panel-bar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.875rem;
      flex-wrap: wrap;
    }
    .panel-tabs {
      display: flex;
      gap: 0.25rem;
      flex-wrap: wrap;
    }
    .panel-tab {
      display: flex;
      align-items: center;
      border: 1px solid var(--border);
      border-radius: var(--r);
      overflow: hidden;
    }
    .panel-tab--active {
      border-color: var(--accent);
      background: var(--surface2);
    }
    .panel-tab__btn {
      padding: 0.25rem 0.625rem;
      color: var(--muted);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: 0;
    }
    .panel-tab__btn:hover { color: var(--text); background: var(--surface2); }
    .panel-tab--active .panel-tab__btn { color: var(--accent); }
    .panel-tab__del {
      padding: 0.125rem 0.3rem;
      font-size: 0.75rem;
      border-left: 1px solid var(--border);
      border-radius: 0;
    }
    .panel-actions { display: flex; align-items: center; }
    .panel-add-btn { font-size: 0.6875rem; color: var(--muted); }
    .panel-add-btn:hover { color: var(--link); }

    /* ── Action bar ─────────────────────────────────────── */
    .action-bar { margin-bottom: 1rem; }

    /* ── Categories grid ────────────────────────────────── */
    #categories {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0.75rem;
      align-items: start;
    }
    .empty { color: var(--muted); font-size: 0.8125rem; }

    /* ── Category card ──────────────────────────────────── */
    .category {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r);
    }
    .category-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5rem 0.75rem;
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
      border-left: 3px solid var(--accent);
    }
    .category-title {
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text);
    }

    /* ── Links ──────────────────────────────────────────── */
    .links-list { padding: 0.25rem 0; }
    .link-item  { position: relative; }
    .link-row {
      display: flex;
      align-items: center;
      padding: 0.2rem 0.75rem;
      gap: 0.5rem;
    }
    .link-name {
      color: var(--link);
      text-decoration: none;
      font-size: 0.8125rem;
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .link-name:hover { color: var(--link-hv); text-decoration: underline; }
    .link-actions { display: none; gap: 0.125rem; flex-shrink: 0; }
    .link-item:hover .link-actions { display: flex; }

    /* ── Add link section ───────────────────────────────── */
    .add-link {
      padding: 0.375rem 0.75rem;
      border-top: 1px solid var(--border);
    }
    .add-link-btn {
      font-size: 0.6875rem;
      color: var(--muted);
      width: 100%;
      text-align: left;
      padding: 0.125rem 0;
      font-family: inherit;
    }
    .add-link-btn:hover { color: var(--link); }

    /* ── Edit form ──────────────────────────────────────── */
    .edit-form { padding: 0.375rem 0.75rem; }

    /* ── Inline forms ───────────────────────────────────── */
    .inline-form {
      display: flex;
      gap: 0.375rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .inline-form input {
      border: 1px solid var(--border);
      border-radius: var(--r);
      padding: 0.2rem 0.5rem;
      font-size: 0.75rem;
      font-family: inherit;
      outline: none;
      min-width: 0;
      background: var(--bg);
      color: var(--text);
    }
    .inline-form input::placeholder { color: var(--muted); }
    .inline-form input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(247,129,102,0.15);
    }
    .inline-form input[name="name"]         { width: 120px; }
    .inline-form input[name="url"]          { width: 185px; }

    /* ── Buttons ────────────────────────────────────────── */
    button {
      cursor: pointer;
      border: none;
      background: none;
      font-family: inherit;
      font-size: 0.6875rem;
      border-radius: var(--r);
      padding: 0.2rem 0.5rem;
      line-height: 1.5;
    }
    .btn-primary { background: var(--accent); color: #fff; font-weight: 700; letter-spacing: 0.03em; }
    .btn-primary:hover { background: #e8705a; }
    .btn-ghost { color: var(--muted); }
    .btn-ghost:hover { background: var(--surface2); color: var(--text); }
    .btn-danger { color: var(--danger); padding: 0.1rem 0.375rem; }
    .btn-danger:hover { background: rgba(248,81,73,0.1); }
    .btn-action { color: var(--muted); }
    .btn-action:hover { background: var(--surface2); color: var(--text); }
    .btn-action.del:hover { color: var(--danger); background: rgba(248,81,73,0.1); }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Dashboard</h1>
    </div>
    <div id="main" set:html={renderMain(panels, activePanel?.id, categories)}></div>
  </div>

  <script>
    import Alpine from 'alpinejs';
    import 'htmx.org';
    window.Alpine = Alpine;
    Alpine.start();
  </script>
</body>
</html>
