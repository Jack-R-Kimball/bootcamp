---
import { getPanels, getCategories } from '../lib/db.js';

const rawUrl  = Astro.url.searchParams.get('url')  ?? '';
const rawName = Astro.url.searchParams.get('name') ?? '';

const panels = getPanels();
const panelsData = panels.map(p => ({
  id: p.id,
  name: p.name,
  cats: getCategories(p.id).map(c => ({ id: c.id, name: c.name })),
}));

// Default: first panel/category that has a "New" category, else first available
let defPanel = panelsData[0]?.id ?? 0;
let defCat   = panelsData[0]?.cats[0]?.id ?? 0;
for (const p of panelsData) {
  const nc = p.cats.find(c => c.name.toLowerCase() === 'new');
  if (nc) { defPanel = p.id; defCat = nc.id; break; }
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Save to Dashboard</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <script is:inline>
    (function () {
      var t = localStorage.getItem('theme');
      if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d1117; --surface: #161b22; --surface2: #21262d;
      --border: #30363d; --text: #e6edf3; --muted: #7d8590;
      --link: #58a6ff; --accent: #f78166; --danger: #f85149; --r: 4px;
    }
    @media (prefers-color-scheme: light) {
      :root {
        --bg: #f6f8fa; --surface: #ffffff; --surface2: #eaeef2;
        --border: #d0d7de; --text: #1f2328; --muted: #656d76;
        --link: #0969da; --accent: #c0392b; --danger: #cf222e;
      }
    }
    html[data-theme="dark"] {
      --bg: #0d1117; --surface: #161b22; --surface2: #21262d;
      --border: #30363d; --text: #e6edf3; --muted: #7d8590;
      --link: #58a6ff; --accent: #f78166; --danger: #f85149;
    }
    html[data-theme="light"] {
      --bg: #f6f8fa; --surface: #ffffff; --surface2: #eaeef2;
      --border: #d0d7de; --text: #1f2328; --muted: #656d76;
      --link: #0969da; --accent: #c0392b; --danger: #cf222e;
    }

    body {
      font-family: ui-monospace, 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
      font-size: 13px;
      background: var(--bg);
      color: var(--text);
      padding: 1.25rem 1.375rem 1rem;
    }

    h2 {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }

    .field { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 0.625rem; }
    label {
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }
    input, select, textarea {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--r);
      color: var(--text);
      font-family: inherit;
      font-size: 0.8125rem;
      padding: 0.35rem 0.5rem;
      width: 100%;
    }
    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: var(--link);
    }
    textarea { resize: none; height: 2.75rem; }

    .row { display: flex; gap: 0.625rem; }
    .row .field { flex: 1; }
    .field-sm { flex: 0 0 7rem !important; }

    .url-bar {
      font-size: 0.6rem;
      color: var(--muted);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      margin-bottom: 0.875rem;
      padding: 0.25rem 0;
      border-bottom: 1px solid var(--border);
    }

    .actions { display: flex; gap: 0.5rem; align-items: center; }
    button {
      font-family: inherit;
      font-size: 0.6875rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: var(--r);
      padding: 0.35rem 0.75rem;
      cursor: pointer;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
    }
    button:hover { color: var(--text); background: var(--surface2); }
    .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
    .btn-primary:hover { filter: brightness(1.1); color: #fff; }

    .status { font-size: 0.75rem; color: var(--muted); margin-left: auto; }
    .status.ok  { color: #3fb950; }
    .status.err { color: var(--danger); }

    .no-panels { color: var(--muted); font-size: 0.75rem; padding: 0.5rem 0; }
  </style>
</head>
<body>
  {panelsData.length === 0 ? (
    <p class="no-panels">No panels yet — open the dashboard and create a panel first.</p>
  ) : (
    <>
      <h2>Save to Dashboard</h2>
      <form id="save-form" autocomplete="off">
        <div class="field">
          <label>Title</label>
          <input id="name-input" name="name" required>
        </div>
        <div class="field">
          <label>Description</label>
          <textarea id="desc-input" name="description" placeholder="optional"></textarea>
        </div>
        <div class="row">
          <div class="field">
            <label>Panel</label>
            <select id="panel-sel" name="panel_id"></select>
          </div>
          <div class="field">
            <label>Category</label>
            <select id="cat-sel" name="category_id"></select>
          </div>
        </div>
        <div class="row">
          <div class="field field-sm">
            <label>Keyword</label>
            <input id="keyword-input" name="keyword" placeholder="optional">
          </div>
          <div class="field">
            <label>Tags</label>
            <input id="tags-input" name="tags" placeholder="tag1, tag2 (optional)">
          </div>
        </div>
        <div class="url-bar" id="url-bar"></div>
        <div class="actions">
          <button type="submit" class="btn-primary">save</button>
          <button type="button" id="cancel-btn">cancel</button>
          <span class="status" id="status"></span>
        </div>
      </form>
    </>
  )}

  <script is:inline define:vars={{ panelsData, defPanel, defCat, rawUrl, rawName }}>
    const panelSel = document.getElementById('panel-sel');
    const catSel   = document.getElementById('cat-sel');
    const urlBar   = document.getElementById('url-bar');
    const nameInput = document.getElementById('name-input');
    const status   = document.getElementById('status');

    if (!panelSel) return; // no panels case

    // Populate panel dropdown
    panelsData.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p.id;
      opt.textContent = p.name;
      panelSel.appendChild(opt);
    });

    function updateCats(panelId) {
      const panel = panelsData.find(p => p.id === panelId);
      catSel.innerHTML = '';
      (panel?.cats ?? []).forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name;
        catSel.appendChild(opt);
      });
      const nc = (panel?.cats ?? []).find(c => c.name.toLowerCase() === 'new');
      catSel.value = nc ? nc.id : (panel?.cats[0]?.id ?? '');
    }

    // Initialise
    nameInput.value = rawName;
    urlBar.textContent = rawUrl;
    panelSel.value = defPanel;
    updateCats(defPanel);
    catSel.value = defCat;

    // Auto-focus title; select all so user can immediately retype if needed
    nameInput.focus();
    nameInput.select();

    panelSel.addEventListener('change', () => updateCats(Number(panelSel.value)));

    document.getElementById('save-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('.btn-primary');
      btn.disabled = true;
      const data = new FormData();
      data.append('name',        nameInput.value.trim());
      data.append('url',         rawUrl);
      data.append('description', document.getElementById('desc-input').value.trim());
      data.append('keyword',     document.getElementById('keyword-input').value.trim());
      data.append('tags',        document.getElementById('tags-input').value.trim());
      data.append('category_id', catSel.value);
      data.append('panel_id',    panelSel.value);
      try {
        const res = await fetch('/api/links', { method: 'POST', body: data });
        if (res.ok) {
          status.textContent = 'Saved!';
          status.className = 'status ok';
          setTimeout(() => window.close(), 800);
        } else {
          status.textContent = 'Error — could not save.';
          status.className = 'status err';
          btn.disabled = false;
        }
      } catch {
        status.textContent = 'Network error.';
        status.className = 'status err';
        btn.disabled = false;
      }
    });

    document.getElementById('cancel-btn').addEventListener('click', () => window.close());
  </script>
</body>
</html>
